{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/badges/**",
              "components/buttons/**",
              "components/forms/**",
              "components/surfaces/**",
              "ui_kits/freebie-tools/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ]
  }
}